# ============================================
# PTC Cortex 环境变量配置
# 复制此文件为 .env.local 并填入实际值
# ============================================

# [必需] DeepSeek LLM API 密钥
DEEPSEEK_API_KEY=sk-xxx

# [必需] DeepSeek API 基础地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# [必需] 接口鉴权密钥，用于保护 API 路由
API_SECRET_KEY=sk-your-secret-key

# [可选] 部署路径前缀，本地开发可留空，部署时按需设置
# NEXT_PUBLIC_BASE_PATH=/chat

# [必需] PostgreSQL 数据库连接串
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# [可选] 火山引擎 ARK API 密钥，用于即梦图片生成
# ARK_API_KEY=

# [可选] SiliconFlow API 密钥，用于图片生成和视觉识别
# SILICONFLOW_API_KEY=

# [可选] 阿里云 OSS 配置，用于图片上传存储
# DEFAULT_OSS_REGION=oss-cn-beijing
# DEFAULT_OSS_BUCKET=your-bucket
# DEFAULT_OSS_ACCESS_KEY_ID=
# DEFAULT_OSS_ACCESS_KEY_SECRET=
# DEFAULT_OSS_DIR=public

# [可选] 服务端口，默认 3000
# PORT=3001
